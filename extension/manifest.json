{
  "manifest_version": 3,
  "name": "KenBot",
  "version": "1.0.0",
  "description": "Automated Kenyan government portal assistant — eCitizen, NTSA, KRA",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.ecitizen.go.ke/*",
    "https://*.ntsa.go.ke/*",
    "https://*.kra.go.ke/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.ecitizen.go.ke/*",
        "https://*.ntsa.go.ke/*",
        "https://*.kra.go.ke/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KenBot"
  },
  "web_accessible_resources": [
    {
      "resources": ["ui/overlay.css"],
      "matches": [
        "https://*.ecitizen.go.ke/*",
        "https://*.ntsa.go.ke/*",
        "https://*.kra.go.ke/*"
      ]
    }
  ]
}
